datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Template {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  description String
  image       String
  demoImages  String[]
  category    String
  tags        String[]
  features    String[]
  price       Decimal  @db.Decimal(12, 2)
  isActive    Boolean  @default(true)
  liveUrl     String?
  pbConfig    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([isActive])
  @@index([slug])
}

model CustomPage {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  templateId  String
  pbConfig    Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
}
